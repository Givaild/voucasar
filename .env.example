# ==========================================
# BANCO DE DADOS
# ==========================================
DB_USER=root
DB_PASSWORD=your_password
DB_HOST=localhost
DB_PORT=3306
DB_NAME=voucasar

# ==========================================
# APLICAÇÃO
# ==========================================
ENVIRONMENT=development
SECRET_KEY=voucasar-super-secret-key-change-in-production
FRONTEND_URL=http://localhost:5173
PORT=8000

# ==========================================
# LOGGING
# ==========================================
LOG_LEVEL=INFO

# ==========================================
# RATE LIMITING (por IP)
# ==========================================
# Limite global padrao: requisicoes permitidas por minuto por IP
RATE_LIMIT_GLOBAL_PER_MINUTE=120
# Limite global padrao: requisicoes permitidas por segundo por IP (rajada)
RATE_LIMIT_GLOBAL_PER_SECOND=20
# Endpoints que NAO devem ter rate limiting (saude, docs, etc.)
# Separados por virgula
RATE_LIMIT_EXCLUDED_PATHS=/health,/,/docs,/redoc,/openapi.json
